{
  "name": "blocks-mcp-chat",
  "version": "0.1.0",
  "type": "module",
  "blocksTemplate": "default",
  "blocksTemplateDescription": "Vite + lit-html frontend with auth, DynamoDB, and realtime (safe default)",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "spec": "blocks-generate-spec",
    "dev:server": "tsx watch aws-blocks/scripts/server.ts",
    "dev": "tsx watch aws-blocks/scripts/server.ts",
    "sandbox": "tsx aws-blocks/scripts/sandbox.ts",
    "sandbox:destroy": "tsx -C cdk aws-blocks/scripts/sandbox-destroy.ts",
    "sandbox:console": "tsx aws-blocks/scripts/console.ts",
    "cleanup": "tsx aws-blocks/scripts/cleanup.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "tsx aws-blocks/scripts/deploy.ts",
    "destroy": "tsx aws-blocks/scripts/destroy.ts",
    "test:e2e": "tsx -C browser test/e2e.test.ts",
    "vendorize": "blocks-vendorize",
    "mcp:tools": "tsx aws-blocks/scripts/mcp-tools.ts",
    "pat:push:sandbox": "tsx aws-blocks/scripts/pat-push.ts sandbox",
    "pat:push:prod": "tsx aws-blocks/scripts/pat-push.ts prod"
  },
  "dependencies": {
    "@aws-blocks/bb-agent": "*",
    "@aws-blocks/blocks": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lit-html": "^3.2.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@aws-sdk/client-ssm": "^3.1090.0",
    "@types/node": "^20.0.0",
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.27.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.3"
  },
  "blocksTemplateVersion": "0.1.0"
}
